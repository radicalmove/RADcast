[Unit]
Description=RADcast dev service
After=network.target

[Service]
Type=simple
User=fldadmin
Group=fldadmin
WorkingDirectory=/home/fldadmin/RADcast
EnvironmentFile=/home/fldadmin/RADcast/.env
ExecStart=/home/fldadmin/RADcast/.venv/bin/gunicorn -k uvicorn.workers.UvicornWorker -w 1 -b 127.0.0.1:8012 radcast.api:app
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
